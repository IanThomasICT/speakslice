# Hugging Face Token (Required for pyannote speaker diarization)
# Get your free token at: https://huggingface.co/settings/tokens
#
# IMPORTANT: You must accept licenses for BOTH models:
# 1. https://huggingface.co/pyannote/speaker-diarization-3.1
# 2. https://huggingface.co/pyannote/segmentation-3.0
#
# Without both licenses accepted, you'll get: "'NoneType' object has no attribute 'eval'"
HF_TOKEN=your_token_here

# Optional: Override default ASR model (tiny, base, small, medium)
# ASR_MODEL=medium

# Optional: Override default port
# PORT=8000

# YouTube Data API v3 Key (Optional - for metadata preview in web UI)
# Get your free API key at: https://console.cloud.google.com/apis/credentials
#
# Setup instructions:
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Enable "YouTube Data API v3"
# 4. Create credentials → API key
# 5. (Optional) Restrict key to YouTube Data API v3 for security
#
# Free tier: 10,000 units/day (~100 video metadata lookups)
# YOUTUBE_API_KEY=your_api_key_here
